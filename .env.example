# Hash bcrypt/argon2 du mot de passe admin unique.
# Générer avec : php -r "echo password_hash('votre-mot-de-passe', PASSWORD_DEFAULT), \"\n\";"
# IMPORTANT : Docker Compose interpole les `$` dans les valeurs de .env
# (il les traite comme des références à d'autres variables). Un hash
# bcrypt contient plusieurs `$` (ex: $2y$12$...) : il faut doubler
# chacun d'eux ($$) dans ce fichier, sinon le hash est tronqué et la
# connexion admin échoue systématiquement avec « Mot de passe incorrect ».
# Exemple : $2y$12$abc... devient $$2y$$12$$abc...
ADMIN_PASSWORD_HASH=

# Chaîne aléatoire longue, utilisée pour lier les sessions PHP.
# Générer avec : php -r "echo bin2hex(random_bytes(32)), \"\n\";"
SESSION_SECRET=

# Taille maximale (en Mo) des archives zip acceptées à l'upload.
MAX_UPLOAD_SIZE_MB=50
