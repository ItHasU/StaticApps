# Hash bcrypt/argon2 du mot de passe admin unique.
# Générer avec : php -r "echo password_hash('votre-mot-de-passe', PASSWORD_DEFAULT), \"\n\";"
ADMIN_PASSWORD_HASH=

# Chaîne aléatoire longue, utilisée pour lier les sessions PHP.
# Générer avec : php -r "echo bin2hex(random_bytes(32)), \"\n\";"
SESSION_SECRET=

# Taille maximale (en Mo) des archives zip acceptées à l'upload.
MAX_UPLOAD_SIZE_MB=50
